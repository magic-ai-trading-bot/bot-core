# Bot Core Environment Variables
# Copy this file to .env and fill in your actual values

# Service Configuration
NODE_ENV=production
LOG_LEVEL=info

# Database - MongoDB Configuration
DATABASE_URL=mongodb://admin:password@mongodb:27017/bot_core?authSource=admin
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=secure_mongo_password_change_me

# Redis Configuration
REDIS_PASSWORD=your-secure-password

# Security Tokens (generate with: openssl rand -hex 32)
JWT_SECRET=generate-a-secure-jwt-secret
INTER_SERVICE_TOKEN=generate-a-secure-random-token
RUST_API_KEY=generate-a-secure-random-token
DASHBOARD_SESSION_SECRET=generate-a-secure-session-secret

# Binance API Keys
# Testnet (safe for development): https://testnet.binance.vision
BINANCE_TESTNET=true
TRADING_ENABLED=false
BINANCE_TESTNET_API_KEY=your-binance-testnet-api-key
BINANCE_TESTNET_SECRET_KEY=your-binance-testnet-secret-key
# Mainnet (production) - USE WITH EXTREME CAUTION
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# xAI / Grok API (used by OpenClaw for AI gateway)
XAI_API_KEY=your-xai-api-key

# Frontend Build Args (baked into Vite build)
VITE_RUST_API_URL=http://your-vps-ip:8080
VITE_WS_URL=ws://your-vps-ip:8080/ws

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://your-vps-ip:3000

# MCP Server
MCP_AUTH_TOKEN=generate-a-64-char-hex-token

# OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=generate-a-secure-gateway-token

# BotCore API credentials (MCP Server -> Rust Engine auth)
BOTCORE_EMAIL=admin@botcore.local
BOTCORE_PASSWORD=your-admin-password

# Telegram Bot (optional - create via @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_USER_ID=your-telegram-user-id

# Resource Limits (Docker)
RUST_MEMORY_LIMIT=2G
RUST_CPU_LIMIT=2
FRONTEND_MEMORY_LIMIT=512M
FRONTEND_CPU_LIMIT=1
MONGO_MEMORY_LIMIT=2G
MONGO_CPU_LIMIT=2
